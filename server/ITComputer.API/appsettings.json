{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=ITComputerDB.sqlite"
  },
  "Jwt": {
    "Key": "ITComputer-SuperSecret-Key-2024-Enterprise-Remote-Support-System-AES256",
    "Issuer": "ITComputer",
    "Audience": "ITComputerClients"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      },
      "Https": {
        "Url": "https://0.0.0.0:5001",
        "Certificate": {
          "Subject": "localhost",
          "Store": "My",
          "Location": "CurrentUser",
          "AllowInvalid": true
        }
      }
    }
  },
  "FileStorage": {
    "RecordingsPath": "recordings",
    "TransfersPath": "transfers",
    "MaxFileSizeMB": 500
  },
  "Security": {
    "MaxFailedLoginAttempts": 5,
    "LockoutMinutes": 15,
    "SessionTimeoutHours": 8,
    "RequireDeviceAuthorization": true,
    "AllowedIPRanges": []
  }
}
